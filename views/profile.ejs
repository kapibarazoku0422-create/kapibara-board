<%- include('partials/head') %>
<main id="main" class="feed-layout feed-layout--single">
  <div class="feed-column">
    <section class="profile-hero">
      <%- include('partials/avatar', { avatar: currentUser.avatarUrl, initial: currentUser.displayName.slice(0, 1), size: 'xlarge' }) %>
      <div><h1><%= currentUser.displayName %></h1><span><%= currentUser.email %></span></div>
      <form method="post" action="/logout"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="plain-action" type="submit">ログアウト</button></form>
    </section>
    <section class="profile-block">
      <div class="result-heading"><h2>作ったボード</h2><span><%= authored.length %>件</span></div>
      <div class="thread-list"><% authored.forEach(function(thread) { %><%- include('partials/thread-card', { thread: thread }) %><% }) %><% if (!authored.length) { %><div class="empty-state empty-state--compact"><span>✎</span><h2>まだボードはありません</h2><a href="/new">最初のボードを作ってみる →</a></div><% } %></div>
    </section>
    <section class="profile-block">
      <div class="result-heading"><h2>保存したボード</h2><span><%= bookmarked.length %>件</span></div>
      <div class="thread-list"><% bookmarked.forEach(function(thread) { %><%- include('partials/thread-card', { thread: thread }) %><% }) %><% if (!bookmarked.length) { %><div class="empty-state empty-state--compact"><span>◇</span><h2>気になるボードを保存してみよう</h2><a href="/">ボードを見つけにいく →</a></div><% } %></div>
    </section>
  </div>
</main>
<%- include('partials/footer') %>
