<%- include('partials/head') %>
<main id="main" class="inner-main thread-page">
  <div class="shell thread-shell">
    <nav class="breadcrumbs" aria-label="パンくず"><a href="/">ホーム</a><span>/</span><a href="/boards/<%= thread.categorySlug %>"><%= thread.categoryName %></a><span>/</span><b>スレッド</b></nav>
    <article class="topic-panel">
      <div class="topic-meta">
        <a class="category-label category-label--<%= thread.categorySlug %>" href="/boards/<%= thread.categorySlug %>"><i></i><%= thread.categoryName %></a>
        <% if (thread.isPinned) { %><span class="pinned-label">運営ピック</span><% } %>
        <time datetime="<%= thread.createdAt.toISOString() %>"><%= formatDate(thread.createdAt) %></time>
      </div>
      <h1><%= thread.title %></h1>
      <div class="topic-author">
        <%- include('partials/avatar', { avatar: thread.authorAvatar, initial: thread.authorInitial, size: 'large' }) %>
        <div><b><%= thread.authorName %></b><span>トピックを作成</span></div>
      </div>
      <div class="rich-body"><%= thread.body %></div>
      <div class="topic-tags"><% thread.tags.forEach(function(tag) { %><a href="/search?q=<%= encodeURIComponent(tag) %>">#<%= tag %></a><% }) %></div>
      <div class="topic-actions">
        <form method="post" action="/threads/<%= thread.id %>/like"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="reaction-button<%= thread.likedByViewer ? ' is-active' : '' %>" type="submit"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="m12 5 7 8h-4v6H9v-6H5l7-8Z"/></svg><span><%= thread.likedByViewer ? '共感しました' : '共感' %></span><b><%= formatNumber(thread.likeCount) %></b></button></form>
        <form method="post" action="/threads/<%= thread.id %>/bookmark"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="plain-action<%= thread.bookmarkedByViewer ? ' is-active' : '' %>" type="submit"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6 3h12v18l-6-4-6 4V3Z"/></svg><%= thread.bookmarkedByViewer ? '保存済み' : 'あとで読む' %></button></form>
        <button class="plain-action share-button" type="button" data-share-title="<%= thread.title %>"><svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="18" cy="5" r="2"/><circle cx="6" cy="12" r="2"/><circle cx="18" cy="19" r="2"/><path d="m8 11 8-5m-8 7 8 5"/></svg>共有</button>
        <span class="topic-views"><%= formatNumber(thread.viewCount) %> views</span>
      </div>
    </article>

    <section class="reply-section" aria-labelledby="reply-heading">
      <div class="reply-heading"><div><p>CONVERSATION</p><h2 id="reply-heading"><%= formatNumber(thread.posts.length) %>件の返信</h2></div><a href="#reply">返信を書く ↓</a></div>
      <div class="reply-list">
        <% thread.posts.forEach(function(post, index) { %>
          <article class="reply-card<%= post.isSolution ? ' reply-card--solution' : '' %>" id="<%= index === thread.posts.length - 1 ? 'latest' : 'post-' + post.number %>">
            <div class="reply-rail"><%- include('partials/avatar', { avatar: post.authorAvatar, initial: post.authorInitial, size: 'medium' }) %><span></span></div>
            <div class="reply-content">
              <header><div><b><%= post.authorName %></b><% if (post.authorRole !== 'member') { %><span class="role-badge"><%= post.authorRole === 'admin' ? '管理者' : 'モデレーター' %></span><% } %><% if (post.isSolution) { %><span class="solution-badge">✓ 参考になった返信</span><% } %></div><div><time datetime="<%= post.createdAt.toISOString() %>" data-relative="<%= post.createdAt.toISOString() %>"><%= formatDate(post.createdAt) %></time><a href="#post-<%= post.number %>">#<%= post.number %></a></div></header>
              <div class="rich-body rich-body--reply"><%= post.body %></div>
              <footer><button type="button" class="mini-action">♡ ありがとう</button><button type="button" class="mini-action quote-button" data-author="<%= post.authorName %>">↩ 返信</button></footer>
            </div>
          </article>
        <% }) %>
      </div>

      <div class="composer" id="reply">
        <% if (currentUser) { %>
          <div class="composer-heading"><%- include('partials/avatar', { avatar: currentUser.avatarUrl, initial: currentUser.displayName.slice(0, 1), size: 'medium' }) %><div><b><%= currentUser.displayName %></b><span>として返信</span></div></div>
          <form method="post" action="/threads/<%= thread.id %>/posts">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <textarea name="body" id="reply-body" minlength="2" maxlength="10000" rows="6" placeholder="あなたの考えを、相手に届く言葉で書いてみましょう。" required></textarea>
            <div class="composer-bottom"><span><b data-character-count>0</b> / 10,000</span><button class="button button--primary" type="submit">返信を投稿 <span>↗</span></button></div>
          </form>
        <% } else { %>
          <div class="login-prompt"><span class="welcome-spark">✦</span><h2>会話に参加しませんか？</h2><p>Googleアカウントですぐに返信できます。</p><a class="button button--primary" href="/auth/google">Googleで参加する</a></div>
        <% } %>
      </div>
    </section>
  </div>
</main>
<%- include('partials/footer') %>
