<%- include('partials/head') %>
<main id="main" class="feed-layout feed-layout--single thread-page" data-live-thread="<%= thread.id %>">
  <div class="feed-column">
    <nav class="breadcrumbs" aria-label="パンくず"><a href="/">ホーム</a><span>›</span><a href="/boards/<%= thread.categorySlug %>">#<%= thread.categoryName %></a></nav>

    <article class="topic">
      <div class="topic-meta">
        <a class="category-chip category-chip--<%= thread.categorySlug %>" href="/boards/<%= thread.categorySlug %>">#<%= thread.categoryName %></a>
        <% if (thread.isPinned) { %><span class="pinned-label">📌 固定</span><% } %>
        <% if (thread.status === 'locked') { %><span class="locked-label">🔒 受付終了</span><% } %>
      </div>
      <h1 class="topic-title"><%= thread.title %></h1>

      <div class="res res--op" id="post-1">
        <%- include('partials/avatar', { avatar: thread.authorAvatar, initial: thread.authorInitial, size: 'medium' }) %>
        <div class="res-main">
          <header class="res-header">
            <span class="res-num">1</span>
            <b class="res-name"><%= thread.authorName %></b>
            <span class="res-role">スレ主</span>
            <time datetime="<%= thread.createdAt.toISOString() %>"><%= formatDate(thread.createdAt) %></time>
          </header>
          <div class="res-body rich-body"><%= thread.body %></div>
          <% if (thread.tags.length) { %><div class="topic-tags"><% thread.tags.forEach(function(tag) { %><a href="/search?q=<%= encodeURIComponent(tag) %>">#<%= tag %></a><% }) %></div><% } %>
        </div>
      </div>

      <div class="topic-actions">
        <form method="post" action="/threads/<%= thread.id %>/like"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="reaction-button<%= thread.likedByViewer ? ' is-active' : '' %>" type="submit"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 21C7 16.5 3 13.3 3 9.5A4.5 4.5 0 0 1 7.5 5c1.8 0 3.4 1 4.5 2.5C13.1 6 14.7 5 16.5 5A4.5 4.5 0 0 1 21 9.5c0 3.8-4 7-9 11.5Z"/></svg><b><%= formatNumber(thread.likeCount) %></b></button></form>
        <form method="post" action="/threads/<%= thread.id %>/bookmark"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button class="plain-action<%= thread.bookmarkedByViewer ? ' is-active' : '' %>" type="submit"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M6 3h12v18l-6-4-6 4V3Z"/></svg><%= thread.bookmarkedByViewer ? '保存済み' : '保存' %></button></form>
        <button class="plain-action share-button" type="button" data-share-title="<%= thread.title %>"><svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="18" cy="5" r="2"/><circle cx="6" cy="12" r="2"/><circle cx="18" cy="19" r="2"/><path d="m8 11 8-5m-8 7 8 5"/></svg>共有</button>
        <% if (currentUser) { %><details class="report-menu"><summary class="plain-action">⚑ 通報</summary><form method="post" action="/threads/<%= thread.id %>/report"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><select name="reason" required><option value="">理由を選ぶ</option><option value="spam">スパム</option><option value="harassment">嫌がらせ</option><option value="privacy">個人情報</option><option value="dangerous">危険な内容</option><option value="other">その他</option></select><textarea name="detail" rows="2" placeholder="補足があればどうぞ"></textarea><button type="submit">管理者に知らせる</button></form></details><% } %>
        <span class="topic-views"><%= formatNumber(thread.viewCount) %> views</span>
      </div>
    </article>

    <section class="reply-section" aria-labelledby="reply-heading">
      <div class="reply-heading">
        <h2 id="reply-heading"><span data-reply-count><%= formatNumber(thread.posts.length) %></span>レス <span class="live-dot">LIVE</span></h2>
        <% if (thread.status !== 'locked') { %><a href="#reply">書き込む ↓</a><% } %>
      </div>
      <div class="res-list" id="live-replies" data-current-user="<%= currentUser?.id || '' %>">
        <% thread.posts.forEach(function(post, index) { %>
          <article class="res<%= post.isSolution ? ' res--solution' : '' %>" id="<%= index === thread.posts.length - 1 ? 'latest' : 'post-' + (post.number + 1) %>" data-post-id="<%= post.id %>" data-number="<%= post.number + 1 %>">
            <%- include('partials/avatar', { avatar: post.authorAvatar, initial: post.authorInitial, size: 'medium' }) %>
            <div class="res-main">
              <header class="res-header">
                <span class="res-num"><%= post.number + 1 %></span>
                <b class="res-name"><%= post.authorName %></b>
                <% if (post.authorRole !== 'member') { %><span class="res-role res-role--staff"><%= post.authorRole === 'admin' ? '管理者' : 'モデレーター' %></span><% } %>
                <% if (post.isSolution) { %><span class="solution-badge">✓ ベスレス</span><% } %>
                <time datetime="<%= post.createdAt.toISOString() %>" data-relative="<%= post.createdAt.toISOString() %>"><%= formatDate(post.createdAt) %></time>
                <a class="res-anchor" href="#post-<%= post.number + 1 %>" aria-label="レス<%= post.number + 1 %>へのリンク">＃</a>
              </header>
              <div class="res-body rich-body"><%= post.body %></div>
              <footer class="res-footer"><button type="button" class="mini-action quote-button" data-number="<%= post.number + 1 %>">↩ &gt;&gt;<%= post.number + 1 %></button></footer>
            </div>
          </article>
        <% }) %>
        <% if (!thread.posts.length) { %><div class="res-empty">まだレスがありません。「2」をゲットしよう。</div><% } %>
      </div>

      <div class="composer" id="reply">
        <% if (thread.status === 'locked') { %>
          <div class="login-prompt"><span>🔒</span><h2>このスレは受付を終了しました</h2><p>これまでのレスはそのまま読めます。</p></div>
        <% } else if (currentUser) { %>
          <form class="composer-form" method="post" action="/threads/<%= thread.id %>/posts">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <%- include('partials/avatar', { avatar: currentUser.avatarUrl, initial: currentUser.displayName.slice(0, 1), size: 'medium' }) %>
            <div class="composer-box">
              <textarea name="body" id="reply-body" rows="1" placeholder="#<%= thread.categoryName %> に書き込む（Ctrl+Enterで送信）" required></textarea>
              <button class="composer-send" type="submit" aria-label="送信"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="m3 12 18-8-6 18-3-7-9-3Z"/></svg></button>
            </div>
          </form>
        <% } else { %>
          <div class="login-prompt"><span>💬</span><h2>書き込むにはログイン</h2><p>Googleアカウントですぐにレスできます。</p><a class="button button--primary" href="/auth/google">Googleではじめる</a></div>
        <% } %>
      </div>
    </section>
  </div>
</main>
<%- include('partials/footer') %>
