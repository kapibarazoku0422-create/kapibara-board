<%- include('partials/head') %>
<main id="main" class="feed-layout">
  <div class="feed-column">
    <div class="feed-top">
      <h1 class="feed-title">ホーム</h1>
      <%- include('partials/sort-tabs', { basePath: '/' }) %>
    </div>

    <% if (currentUser) { %>
      <form class="quick-post" method="post" action="/quick-post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <%- include('partials/avatar', { avatar: currentUser.avatarUrl, initial: currentUser.displayName.slice(0, 1), size: 'medium' }) %>
        <div class="quick-post-body">
          <label class="visually-hidden" for="quick-post-body">いまどうしてる？</label>
          <textarea id="quick-post-body" name="body" rows="1" placeholder="いまどうしてる？" required></textarea>
          <div class="quick-post-bottom">
            <span>「総合」にボードとして投稿されます</span>
            <button class="button button--primary" type="submit">投稿</button>
          </div>
        </div>
      </form>
    <% } else { %>
      <div class="guest-banner">
        <div><b>ようこそ、Kapibara Boardへ</b><span>読むのは自由。書き込むならログイン。</span></div>
        <a class="login-button" href="/auth/google"><span class="google-g">G</span> Googleではじめる</a>
      </div>
    <% } %>

    <div class="thread-list" id="latest" data-live-feed="">
      <% threads.forEach(function(thread) { %><%- include('partials/thread-card', { thread: thread }) %><% }) %>
      <% if (!threads.length) { %><div class="empty-state"><span>◌</span><h2>まだボードがありません</h2><p>最初のボードを作ってみよう。</p></div><% } %>
    </div>
  </div>

  <aside class="right-rail">
    <section class="rail-card">
      <h2 class="rail-title">トレンド</h2>
      <ol class="trend-list">
        <% trending.forEach(function(thread, index) { %>
          <li>
            <span class="trend-rank"><%= index + 1 %></span>
            <div>
              <a href="/threads/<%= thread.id %>"><%= thread.title %></a>
              <small><%= thread.categoryName %> · レス<%= formatNumber(thread.replyCount) %>件</small>
            </div>
          </li>
        <% }) %>
      </ol>
    </section>
    <section class="rail-card rail-card--stats">
      <h2 class="rail-title">コミュニティ</h2>
      <div class="rail-stats">
        <div><strong><%= formatNumber(stats.members) %></strong><span>メンバー</span></div>
        <div><strong><%= formatNumber(stats.threads) %></strong><span>ボード</span></div>
        <div><strong><%= formatNumber(stats.posts) %></strong><span>レス</span></div>
        <div><strong class="online-now"><i></i><%= formatNumber(stats.online) %></strong><span>オンライン</span></div>
      </div>
      <% if (!currentUser) { %><a class="rail-cta" href="/auth/google">Googleで参加する →</a><% } else { %><a class="rail-cta" href="/new">ボードを作る →</a><% } %>
    </section>
  </aside>
</main>
<%- include('partials/footer') %>
