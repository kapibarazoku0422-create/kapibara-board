<%- include('partials/head') %>
<main id="main" class="feed-layout feed-layout--single">
  <div class="feed-column">
    <div class="board-header board-header--<%= category.slug %>">
      <div class="board-header-main">
        <h1><span class="board-hash">#</span><%= category.name %></h1>
        <p><%= category.description %></p>
      </div>
      <div class="board-header-meta"><strong><%= formatNumber(category.threadCount) %></strong><span>スレ</span></div>
    </div>
    <div class="feed-top">
      <%- include('partials/sort-tabs', { basePath: '/boards/' + category.slug }) %>
      <a class="button button--primary board-new" href="/new">＋ スレ立て</a>
    </div>
    <div class="thread-list">
      <% if (!threads.length) { %><div class="empty-state"><span>◌</span><h2>ここはまだ静かみたい</h2><p>一番乗りでスレを立ててみよう。</p><a class="button button--primary" href="/new">スレを立てる</a></div><% } %>
      <% threads.forEach(function(thread) { %><%- include('partials/thread-card', { thread: thread }) %><% }) %>
    </div>
  </div>
</main>
<%- include('partials/footer') %>
