<article class="thread-card<%= thread.isPinned ? ' thread-card--pinned' : '' %>">
  <%- include('avatar', { avatar: thread.authorAvatar, initial: thread.authorInitial, size: 'medium' }) %>
  <div class="thread-main">
    <div class="thread-eyebrow">
      <b class="thread-author"><%= thread.authorName %></b>
      <a class="category-chip category-chip--<%= thread.categorySlug %>" href="/boards/<%= thread.categorySlug %>">#<%= thread.categoryName %></a>
      <span aria-hidden="true">·</span>
      <time datetime="<%= thread.lastActivityAt.toISOString() %>" data-relative="<%= thread.lastActivityAt.toISOString() %>"><%= formatDate(thread.lastActivityAt) %></time>
      <% if (thread.isPinned) { %><span class="pinned-label">📌 固定</span><% } %>
    </div>
    <h3 class="thread-title"><a href="/threads/<%= thread.id %>"><%= thread.title %><small>(<%= formatNumber(thread.replyCount) %>)</small></a></h3>
    <p class="thread-excerpt"><%= thread.excerpt %></p>
    <div class="thread-bottom">
      <span class="thread-metric"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8Z"/></svg><%= formatNumber(thread.replyCount) %></span>
      <span class="thread-metric thread-metric--like"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 21C7 16.5 3 13.3 3 9.5A4.5 4.5 0 0 1 7.5 5c1.8 0 3.4 1 4.5 2.5C13.1 6 14.7 5 16.5 5A4.5 4.5 0 0 1 21 9.5c0 3.8-4 7-9 11.5Z"/></svg><%= formatNumber(thread.likeCount) %></span>
      <span class="thread-metric metric-views"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="2.5"/></svg><%= formatNumber(thread.viewCount) %></span>
      <div class="thread-tags"><% thread.tags.slice(0, 3).forEach(function(tag) { %><span>#<%= tag %></span><% }) %></div>
    </div>
  </div>
</article>
