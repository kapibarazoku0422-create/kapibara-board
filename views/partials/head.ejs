<!doctype html>
<html lang="ja" data-theme="dark">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#121317">
  <meta name="description" content="匿名ノリでゆるく語れるコミュニティ掲示板 Kapibara Board。Googleアカウントですぐ参加。">
  <title><%= title %> | Kapibara Board</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <link rel="stylesheet" href="/styles.css?v=<%= assetVersion %>">
  <script src="/app.js?v=<%= assetVersion %>" defer></script>
</head>
<body>
  <a class="skip-link" href="#main">本文へ移動</a>
  <header class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/" aria-label="Kapibara Board ホーム">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 36 36"><circle class="capy-ear" cx="9" cy="9" r="5"/><circle class="capy-ear" cx="27" cy="9" r="5"/><rect class="capy-head" x="4" y="7" width="28" height="25" rx="11"/><circle class="capy-eye" cx="12" cy="17" r="1.5"/><circle class="capy-eye" cx="24" cy="17" r="1.5"/><rect class="capy-muzzle" x="11" y="20" width="14" height="8" rx="4"/><circle class="capy-nose" cx="18" cy="22" r="2"/></svg>
        </span>
        <span class="brand-word">Kapibara<em>Board</em></span>
      </a>
      <form class="topbar-search" action="/search" method="get" role="search">
        <svg aria-hidden="true" viewBox="0 0 24 24"><path d="m21 21-4.35-4.35m2.35-5.65a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z"/></svg>
        <input type="search" name="q" placeholder="検索" aria-label="ボードを検索">
        <kbd>⌘K</kbd>
      </form>
      <nav class="topbar-actions" aria-label="メインナビゲーション">
        <button class="icon-button theme-toggle" type="button" aria-label="表示テーマを切り替える">
          <svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.42 1.42m11.3 11.3 1.42 1.42M2 12h2m16 0h2M4.93 19.07l1.42-1.42m11.3-11.3 1.42-1.42"/></svg>
        </button>
        <% if (currentUser) { %>
          <a class="icon-button topbar-dm" href="/messages" aria-label="DM">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8Z"/></svg>
            <% if (unreadMessages) { %><b><%= unreadMessages > 99 ? '99+' : unreadMessages %></b><% } %>
          </a>
          <a class="post-button" href="/new"><span>＋</span><i>ボード作成</i></a>
          <a class="avatar-link" href="/me" aria-label="マイページ">
            <% if (currentUser.avatarUrl) { %><img src="<%= currentUser.avatarUrl %>" alt=""><% } else { %><span><%= currentUser.displayName.slice(0, 1) %></span><% } %>
          </a>
        <% } else { %>
          <a class="login-button" href="/auth/google"><span class="google-g">G</span> ログイン</a>
        <% } %>
      </nav>
    </div>
  </header>
  <% if (flash) { %>
    <div class="flash flash--<%= flash.type %>" role="status"><span><%= flash.message %></span><button type="button" aria-label="閉じる">×</button></div>
  <% } %>
  <% if (demoMode) { %>
    <div class="preview-bar"><span></span> おためし表示中 — データベースをつなぐと投稿できるようになります</div>
  <% } %>
  <div class="app">
    <aside class="side-nav" aria-label="サイドナビゲーション">
      <div class="side-nav-inner">
        <nav class="side-links">
          <a class="side-link<%= currentPath === '/' ? ' is-active' : '' %>" href="/"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="m3 10 9-7 9 7v10a1 1 0 0 1-1 1h-5v-6h-6v6H4a1 1 0 0 1-1-1V10Z"/></svg>ホーム</a>
          <a class="side-link<%= currentPath === '/search' ? ' is-active' : '' %>" href="/search"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="m21 21-4.35-4.35m2.35-5.65a8 8 0 1 1-16 0 8 8 0 0 1 16 0Z"/></svg>検索</a>
          <% if (currentUser) { %>
            <a class="side-link<%= currentPath === '/members' ? ' is-active' : '' %>" href="/members"><svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="9" cy="8" r="4"/><path d="M2 21c0-3.5 3-6 7-6s7 2.5 7 6"/><circle cx="17.5" cy="9" r="3"/><path d="M17 15c3 .2 5 2.3 5 5"/></svg>メンバー</a>
            <a class="side-link<%= currentPath.startsWith('/messages') ? ' is-active' : '' %>" href="/messages"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8Z"/></svg>DM<% if (unreadMessages) { %><b class="side-badge"><%= unreadMessages > 99 ? '99+' : unreadMessages %></b><% } %></a>
            <a class="side-link<%= currentPath === '/me' ? ' is-active' : '' %>" href="/me"><svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 3.5-7 8-7s8 3 8 7"/></svg>マイページ</a>
            <% if (currentUser.role === 'admin') { %><a class="side-link side-link--admin<%= currentPath === '/admin' ? ' is-active' : '' %>" href="/admin"><svg aria-hidden="true" viewBox="0 0 24 24"><path d="M12 2 4 6v6c0 5 3.5 8.5 8 10 4.5-1.5 8-5 8-10V6l-8-4Z"/></svg>管理</a><% } %>
          <% } %>
        </nav>
        <div class="side-section">
          <p class="side-heading">カテゴリ</p>
          <nav class="board-links">
            <% (navCategories || []).forEach(function(category) { %>
              <a class="board-link board-link--<%= category.slug %><%= currentPath === '/boards/' + category.slug ? ' is-active' : '' %>" href="/boards/<%= category.slug %>">
                <span class="board-hash">#</span><%= category.name %><small><%= formatNumber(category.threadCount) %></small>
              </a>
            <% }) %>
          </nav>
        </div>
        <% if (currentUser) { %>
          <a class="side-new-thread" href="/new">＋ 新しいボードを作る</a>
        <% } else { %>
          <div class="side-login-card">
            <p>参加すると書き込み・DM・いいねができます。</p>
            <a class="login-button login-button--wide" href="/auth/google"><span class="google-g">G</span> Googleではじめる</a>
          </div>
        <% } %>
      </div>
    </aside>
    <div class="content">
